{
  "schemaVersion": 38,
  "title": "System & Process Metrics (Mimir / OTel Hostmetrics)",
  "timezone": "browser",
  "refresh": "30s",
  "uid": "system-process-mimir-otel",
  "version": 1,
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "type": "timeseries",
      "title": "High CPU Systems (%)",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 8 },
      "datasource": { "uid": "mimir-prometheus", "type": "prometheus" },
      "targets": [
        {
          "expr": "topk(10, 100 * (1 - avg by(instance) (rate(system_cpu_time_seconds_total{state=\"idle\"}[5m])))) or topk(10, 100 * (1 - avg by(instance) (rate(system_cpu_time{state=\"idle\"}[5m]))))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Memory Usage %",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 8 },
      "datasource": { "uid": "mimir-prometheus", "type": "prometheus" },
      "targets": [
        {
          "expr": "100 * avg by(instance) (system_memory_utilization{state=\"used\"}) or 100 * (sum by(instance) (system_memory_usage_bytes{state=\"used\"}) / clamp_min(sum by(instance) (system_memory_limit_bytes), 1)) or 100 * (sum by(instance) (system_memory_usage{state=\"used\"}) / clamp_min(sum by(instance) (system_memory_limit), 1))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Load Average (5m)",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 8 },
      "datasource": { "uid": "mimir-prometheus", "type": "prometheus" },
      "targets": [
        {
          "expr": "system_cpu_load_average_5m or system_cpu_load_average_1m or system_load_average_5m",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Disk Read Throughput",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "uid": "mimir-prometheus", "type": "prometheus" },
      "targets": [
        {
          "expr": "sum by(instance) (rate(system_disk_io_bytes_total{direction=\"read\"}[5m])) or sum by(instance) (rate(system_disk_io_bytes{direction=\"read\"}[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Disk Write Throughput",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "uid": "mimir-prometheus", "type": "prometheus" },
      "targets": [
        {
          "expr": "sum by(instance) (rate(system_disk_io_bytes_total{direction=\"write\"}[5m])) or sum by(instance) (rate(system_disk_io_bytes{direction=\"write\"}[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Network Receive",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "datasource": { "uid": "mimir-prometheus", "type": "prometheus" },
      "targets": [
        {
          "expr": "sum by(instance) (rate(system_network_io_bytes_total{direction=\"receive\"}[5m])) or sum by(instance) (rate(system_network_io_bytes{direction=\"receive\"}[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Network Transmit",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "datasource": { "uid": "mimir-prometheus", "type": "prometheus" },
      "targets": [
        {
          "expr": "sum by(instance) (rate(system_network_io_bytes_total{direction=\"transmit\"}[5m])) or sum by(instance) (rate(system_network_io_bytes{direction=\"transmit\"}[5m]))",
          "refId": "A"
        }
      ]
    }
  ]
}
