# Example environment overrides for local development / CI
# IMPORTANT: replace any `changeme` or example values before using in production.
# Never commit real secrets to git — use a secret manager for production.

# Database
POSTGRES_PASSWORD=example_postgres_password_ChangeMe
# Optional: override full database URL (will be constructed from POSTGRES_PASSWORD by docker-compose)
# DATABASE_URL=postgresql://beobservant:example_postgres_password_ChangeMe@postgres:5432/beobservant

# Server / application
HOST=0.0.0.0
PORT=4319
LOG_LEVEL=info

# Secrets (replace with secure random values)
JWT_SECRET_KEY=replace_with_a_strong_jwt_secret_key
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=replace_with_a_strong_admin_password
DEFAULT_ADMIN_EMAIL=admin@example.com

# Auth provider mode: local | keycloak
AUTH_PROVIDER=local
AUTH_PASSWORD_FLOW_ENABLED=false

# OIDC / Keycloak (required when AUTH_PROVIDER=keycloak)
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_AUDIENCE=
OIDC_JWKS_URL=
OIDC_SCOPES=openid profile email
OIDC_AUTO_PROVISION_USERS=true

# Optional Keycloak admin API for app-driven user creation
KEYCLOAK_USER_PROVISIONING_ENABLED=false
KEYCLOAK_ADMIN_URL=
KEYCLOAK_ADMIN_REALM=
KEYCLOAK_ADMIN_CLIENT_ID=
KEYCLOAK_ADMIN_CLIENT_SECRET=

# OTLP / agents
DEFAULT_OTLP_TOKEN=replace_with_a_secure_otlp_token_eg_bo_xxx
OTLP_INGEST_TOKEN=
AGENT_HEARTBEAT_TOKEN=

# Encryption (Fernet key for DATA_ENCRYPTION_KEY — generate with `python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"`)
DATA_ENCRYPTION_KEY=

# Webhook / inbound tokens
INBOUND_WEBHOOK_TOKEN=

# Grafana (optional)
GRAFANA_PASSWORD=admin
GRAFANA_API_KEY=

# CORS / proxy
CORS_ORIGINS=http://localhost:5173
TRUST_PROXY_HEADERS=false

# Optional cloud / backup settings used by docker-compose
S3_BUCKET=beobservant-backup
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Add any additional environment variables you need for local testing here.
